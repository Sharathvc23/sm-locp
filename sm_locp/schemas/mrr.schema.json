{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://stellarminds.ai/schemas/mrr/v1",
  "title": "Machine-Readable Regulation (MRR)",
  "description": "Schema for executable regulatory rules in the Open Compliance Protocol",
  "type": "object",
  "required": ["rule_id", "agency"],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri",
      "description": "Reference to the MRR JSON Schema"
    },
    "rule_id": {
      "type": "string",
      "description": "Unique identifier for the rule",
      "pattern": "^[a-z0-9-]+$"
    },
    "agency": {
      "type": "string",
      "description": "Regulatory agency or authority issuing the rule"
    },
    "title": {
      "type": "string",
      "description": "Human-readable title of the rule"
    },
    "version": {
      "type": "string",
      "description": "Version of this MRR encoding"
    },
    "description": {
      "type": "string",
      "description": "Detailed description of what the rule requires"
    },
    "conditions": {
      "type": "array",
      "description": "List of conditions that must be evaluated",
      "items": {
        "$ref": "#/$defs/condition"
      }
    },
    "applicability": {
      "type": "object",
      "description": "Criteria determining when this rule applies",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    },
    "certification": {
      "type": "object",
      "description": "How compliance can be certified",
      "properties": {
        "self_certifiable": {
          "type": "boolean",
          "description": "Whether operators can self-certify compliance"
        },
        "proof_format": {
          "type": "string",
          "description": "Format for compliance proof"
        },
        "ttl_seconds": {
          "type": ["integer", "null"],
          "description": "Time-to-live for compliance credentials (null for no expiration)",
          "minimum": 60,
          "maximum": 86400
        }
      }
    }
  },
  "$defs": {
    "condition": {
      "type": "object",
      "required": ["field", "operator", "value"],
      "properties": {
        "field": {
          "type": "string",
          "description": "Dot-notation path to the data field"
        },
        "operator": {
          "type": "string",
          "enum": ["==", "!=", "<", "<=", ">", ">=", "in", "not_in", "contains", "matches"]
        },
        "value": {
          "description": "The value to compare against (number, string, array, or regex pattern)"
        },
        "required": {
          "type": "boolean",
          "default": true,
          "description": "Whether this condition must pass for compliance"
        },
        "weight": {
          "type": "number",
          "description": "Weight for scoring (0.0-1.0)",
          "minimum": 0,
          "maximum": 1
        },
        "description": {
          "type": "string",
          "description": "Human-readable description of this condition"
        },
        "error_message": {
          "type": "string",
          "description": "Message to display if condition fails"
        }
      }
    }
  }
}
